# Copy to .env and fill in. Never commit the filled-in version.

ENVIRONMENT=development

# Supabase -> Project Settings -> Database -> Connection string (URI), psycopg driver.
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@<host>:5432/postgres

# "dev" accepts any request as a fixed test founder. Refused when ENVIRONMENT=production.
# "supabase" verifies the JWT the frontend receives from Supabase Auth.
AUTH_PROVIDER=dev

# Required only when AUTH_PROVIDER=supabase.
# Supabase -> Project Settings -> API -> JWT Settings -> JWT Secret.
SUPABASE_JWT_SECRET=

# Any long random string. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Discovery calls / Google Calendar ---
# Leave blank to run in stub mode (deterministic slots, placeholder meeting links).
# To go live: enable the Calendar API in Google Cloud, create a service account,
# share the host calendar with the service account's email, and paste values here.
#   GOOGLE_CALENDAR_ID: the host calendar id (e.g. team@goxl.in or the calendar's id)
# Provide the service-account key ONE of two ways -- FILE is far easier (the key
# is multi-line JSON, which .env cannot store inline):
#   GOOGLE_CALENDAR_CREDENTIALS_FILE  = google-credentials.json   (recommended; save the key file next to this)
#   GOOGLE_CALENDAR_CREDENTIALS_JSON  = {"type":"service_account",...}   (must be ONE line)
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_CREDENTIALS_FILE=
GOOGLE_CALENDAR_CREDENTIALS_JSON=
DISCOVERY_CALL_DURATION_MINUTES=45
DISCOVERY_TIMEZONE=Asia/Kolkata

SENTRY_DSN=
LOG_LEVEL=INFO
